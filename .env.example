# PostgreSQL storage. Use one of these in production.
DATABASE_URL="postgresql://user:password@host:5432/iotbridge"
# POSTGRES_URL="postgresql://user:password@host:5432/iotbridge"

# Set true for providers that require SSL, such as many hosted PostgreSQL services.
# Set false for a local PostgreSQL instance that does not use SSL.
IOTBRIDGE_POSTGRES_SSL=false

# Optional bootstrap admin for production.
IOTBRIDGE_ADMIN_EMAIL="admin@campus.edu"
IOTBRIDGE_ADMIN_PASSWORD="change-this-password"
IOTBRIDGE_ADMIN_NAME="Admin Campus"

# Demo users keep seeded device ownership and access grants usable during demos.
IOTBRIDGE_DEMO_USER_PASSWORD="Demo12345!"
IOTBRIDGE_SEED_DEMO_USERS=true

# Midtrans Snap Sandbox. Keep the server key only on the backend.
MIDTRANS_SERVER_KEY="SB-Mid-server-your-server-key"
MIDTRANS_CLIENT_KEY="SB-Mid-client-your-client-key"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-your-client-key"

# Optional alias if this code is reused in a Vite frontend.
VITE_MIDTRANS_CLIENT_KEY="SB-Mid-client-your-client-key"
